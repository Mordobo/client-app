# Copy to `.env` for LOCAL development. Do not commit `.env`.
# Local dev MUST target QA (or localhost API) — never production. See .cursor/rules/localenvironment.mdc

EXPO_PUBLIC_ENV=development
EXPO_PUBLIC_API_ENV=qa
EXPO_PUBLIC_API_URL=https://mordobo-api-qa.onrender.com

# Optional: local Express API (requires API on localhost:3000)
# EXPO_PUBLIC_API_ENV=localhost

# NEVER set these in local `.env` — production is configured via EAS / Netlify only:
# EXPO_PUBLIC_API_ENV=production
# EXPO_PUBLIC_API_URL_PROD=https://mordobo-api-prod.onrender.com

# Supabase Realtime: QA project tied to the QA API (NOT the production Supabase project)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Google Maps (required for Service Area map on Android)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Public legal address shown in Azul compliance pages and receipts.
# REQUIRED for Azul merchant review: full registered street address of MORDOBO EIRL
# (street, city, country), e.g. "Calle Ejemplo #123, Santo Domingo, República Dominicana"
EXPO_PUBLIC_COMPANY_ADDRESS=

# Google Sign-In (Expo / native)
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=
# EXPO_PUBLIC_EXPO_PROJECT_FULL_NAME=@your-account/mordobo
